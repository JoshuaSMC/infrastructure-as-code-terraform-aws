# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform lock file — commit this to pin provider versions
# .terraform.lock.hcl  ← intentionally NOT ignored

# Terraform working directory
.terraform/

# Variable files with secrets
*.tfvars
!terraform.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# macOS
.DS_Store

# IDEs
.idea/
*.iml
