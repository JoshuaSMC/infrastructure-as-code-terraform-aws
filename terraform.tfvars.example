aws_region         = "us-east-1"
project_name       = "tasks-api"
environment        = "prod"
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]
container_port     = 8080
desired_count      = 1
cpu                = 256
memory             = 512

# Optional: override the default ECR image
# container_image = "ghcr.io/joshuasmc/tasks-api:latest"
